# Copy to .env and adjust as needed
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///aegis.sqlite

# Hermes Agent integration
# Leave HERMES_API_URL empty to use the deterministic local council/reasoner.
# Point it at the Hermes sandbox OpenAI-compatible endpoint to use the real agent:
#   HERMES_API_URL=http://localhost:8642/v1
HERMES_API_URL=
HERMES_API_KEY=
HERMES_MODEL=nvidia/nemotron-3-super-120b-a12b
HERMES_TIMEOUT=90
# Max tokens per Hermes reasoning turn.
HERMES_MAX_TOKENS=400
# This Hermes build hangs on the OpenAI `tools` param, so tool-augmented mode is
# used by default (tools run server-side, results injected, real reasoning).
# Set to 1 only against a build with working OpenAI tool_calls.
HERMES_NATIVE_TOOLS=

# Optional: protect the /hermes/tools/* HTTP surface the sandbox calls.
HERMES_TOOL_TOKEN=
