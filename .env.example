# Copy to .env and adjust as needed
FLASK_APP=run.py
# Dev server: leave FLASK_DEBUG unset in any shared/public environment — the
# Werkzeug debugger is a remote-code-execution surface. Set FLASK_DEBUG=1 only
# for strictly-local development.
FLASK_DEBUG=
HOST=0.0.0.0
PORT=5000
# Leave SECRET_KEY unset to use a random per-process key; set it for stable sessions.
SECRET_KEY=
DATABASE_URL=sqlite:///aegis.sqlite

# Hermes Agent integration
# Leave HERMES_API_URL empty to use the deterministic local council/reasoner.
# Point it at the Hermes sandbox OpenAI-compatible endpoint to use the real agent:
#   HERMES_API_URL=http://localhost:8642/v1
HERMES_API_URL=
HERMES_API_KEY=
HERMES_MODEL=nvidia/nemotron-3-super-120b-a12b
HERMES_TIMEOUT=90
# Shorter timeout for the interactive chatbot so it fails fast if the model is busy.
HERMES_CHAT_TIMEOUT=30
# Max tokens per Hermes reasoning turn.
HERMES_MAX_TOKENS=400
# This Hermes build hangs on the OpenAI `tools` param, so tool-augmented mode is
# used by default (tools run server-side, results injected, real reasoning).
# Set to 1 only against a build with working OpenAI tool_calls.
HERMES_NATIVE_TOOLS=

# Optional: protect the /hermes/tools/* HTTP surface the sandbox calls.
HERMES_TOOL_TOKEN=

# --- Guardrail / spend policy --------------------------------------------- #
# The spend mandate lives in agent-cfo.policy.yaml; these env vars override it.
# AEGIS_AUTO_APPROVE_LIMIT, AEGIS_PER_TRANSACTION_CAP, AEGIS_DAILY_BUDGET,
# AEGIS_MONTHLY_BUDGET, AEGIS_ALLOWLIST="Vendor A,Vendor B", AEGIS_BLOCKLIST=...,
# AEGIS_ALLOWLIST_ENABLED=0 to disable the allowlist.
#
# DEVELOPMENT ONLY: disable the spend guardrail (returns ALLOW, loud dev_bypass).
# Never set this for the demo. Self-modification of the boundary stays denied.
GUARDRAILS_DISABLED=
# Same-origin CSRF guard is ON by default; set AEGIS_CSRF=off only to debug.
AEGIS_CSRF=
# Optional shared-credential HTTP Basic Auth over the whole UI for a public demo:
#   AEGIS_BASIC_AUTH=user:password   (or just a password)
AEGIS_BASIC_AUTH=

# --- Optional: real Stripe test-mode reconciliation ----------------------- #
# Set STRIPE_LIVE=1 and a test key to reconcile the ledger against real Stripe
# test-mode charges instead of the deterministic mock (falls back to mock on error).
STRIPE_LIVE=
STRIPE_SECRET_KEY=
